# ================================================================
# RajLaxmi Jewellers — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git (add to .gitignore)
# ================================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/rajlaxmi_db
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (generate a strong 256-bit secret)
JWT_SECRET=replace-with-min-32-char-secret-key-for-production
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# Email (Gmail App Password — not your normal password)
# Get from: Google Account → Security → 2-Step Verification → App passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENABLED=false
MAIL_USERNAME=rajlaxmijewellers.gaya@gmail.com
MAIL_PASSWORD=your_16_char_gmail_app_password

# CORS (comma-separated allowed frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://rajlaxmijewellers.com

# File Upload
FILE_UPLOAD_DIR=uploads/

# Railway/Render auto-sets PORT
PORT=8080
