# ================================================================
# RajLaxmi Jewellers — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git (add to .gitignore)
# ================================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://HOST:PORT/DBNAME
DB_USERNAME=railway_postgres_user
DB_PASSWORD=your_strong_password_here

# Redis (optional for free/trial demo)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (generate a strong 256-bit secret)
JWT_SECRET=replace-with-min-32-char-secret-key-for-production
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# Email over HTTPS (required on Railway Free/Trial/Hobby)
RESEND_API_KEY=your_resend_api_key
MAIL_FROM="Raj Laxmi Jewellers <noreply@rajlaxmijewellery.in>"

# SMTP fallback for local development or Railway Pro
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENABLED=true
MAIL_USERNAME=rajlaxmijewellers.gaya@gmail.com
MAIL_PASSWORD=your_16_char_gmail_app_password

# Auth
AUTH_EXPOSE_OTP=false

# Phone OTP checkout (MSG91 Widget credentials; Railway variables only)
SMS_ENABLED=false
SMS_PROVIDER=MSG91
SMS_API_KEY=
SMS_WIDGET_ID=
SMS_OTP_EXPIRY_MINUTES=10

# Optional local development admin seed (never enable in production)
DEV_ADMIN_ENABLED=false
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=

# CORS (comma-separated allowed frontend origins)
CORS_ALLOWED_ORIGINS=https://rajlaxmijewellery.in,https://www.rajlaxmijewellery.in,https://your-vercel-app.vercel.app

# File Upload
# Railway: attach a persistent volume to /app/uploads. The platform-provided
# RAILWAY_VOLUME_MOUNT_PATH is used automatically when FILE_UPLOAD_DIR is unset.
FILE_UPLOAD_DIR=uploads/

# Railway/Render auto-sets PORT
PORT=8080
